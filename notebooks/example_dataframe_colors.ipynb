       "<script>\n",
       "$(document).ready(function() {\n",
       "    var table = $(&apos;#mainTable&apos;).DataTable({\n",
       "        paging: true,\n",
       "        searching: true,\n",
       "        info: true,\n",
       "        ordering: true,\n",
       "        pageLength: 15,\n",
       "        lengthMenu: [[5, 15, 50, -1], [5, 15, 50, &apos;All&apos;]],\n",
       "        scrollX: true,\n",
       "        select: true,\n",
       "        keys: true,\n",
       "        columnDefs: [\n",
       "            { targets: [3, 4, 6], className: &apos;dt-right&apos; },\n",
       "            { targets: [3], render: $.fn.dataTable.render.number( &apos;,&apos;, &apos;.&apos;, 1, &apos;&apos;, &apos;&nbsp;&nbsp;&apos; ) },\n",
       "            { targets: [4], render: $.fn.dataTable.render.number( &apos;,&apos;, &apos;.&apos;, 0, &apos;&apos;, &apos;&nbsp;&nbsp;&apos; ) },\n",
       "            { targets: [6], visible: false,  searchable: false}\n",
       "        ],\n",
       "    });\n",
       "    \n",
       "    // Capture original state for the reset button\n",
       "    // JSON parse/stringify creates a clean copy of the ordering array\n",
       "    var initialOrder = table.order() ? JSON.parse(JSON.stringify(table.order())) : [];\n",
       "    var initialLength = table.page.len();\n",
       "\n",
       "    // Add Reset and Column buttons\n",
       "    var resetBtn = $(&apos;<button id=\"resetBtn\">Reset</button>&apos;);\n",
       "    var columnBtn = $(&apos;<button id=\"columnBtn\">Columns</button>&apos;);\n",
       "    var columnList = $(&apos;<div id=\"columnList\"></div>&apos;);\n",
