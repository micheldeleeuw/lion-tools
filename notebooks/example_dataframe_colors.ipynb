       "    var deselectAllBtn = $(&apos;<button class=\"select-btn\">Deselect All</button>&apos;);\n",
       "    selectButtonsDiv.append(selectAllBtn);\n",
       "    selectButtonsDiv.append(deselectAllBtn);\n",
       "    \n",
       "    var columnItemsContainer = $(&apos;<div class=\"column-items-container\"></div>&apos;);\n",
       "    \n",
