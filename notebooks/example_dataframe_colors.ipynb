       "                columnString = selectedColumns.map(function(col) {\n",
       "                    return &apos;\"&apos; + col + &apos;\"&apos;;\n",
       "                }).join(&apos;, &apos;);\n",
       "            } else if (format === &apos;quoted-newline&apos;) {\n",
       "                columnString = selectedColumns.map(function(col) {\n",
       "                    return &apos;\"&apos; + col + &apos;\"&apos;;\n",
       "                }).join(&apos;,\\n&apos;) + &apos;,&apos;;\n",
